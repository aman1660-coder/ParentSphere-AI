# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/parentsphere

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Parentsphere <no-reply@parentsphere.local>"

# OpenAI - leave empty to use the built-in safe demo assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Razorpay - leave blank for demo payments, or add test/production keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

# Frontend
VITE_API_URL=http://localhost:5000/api
VITE_RAZORPAY_KEY_ID=
